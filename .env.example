# ── Stackarr ─────────────────────────────────────────────────────────────────
STACKARR_NAME=Stackarr
STACKARR_ACCENT=#d98c3f
# STACKARR_URL_BASE=stackarr        # set if served under a subpath / reverse proxy
# STACKARR_ADMINS=jon               # ABS usernames that are Stackarr admins (comma-sep)

# ── Audiobookshelf (login + library + listening history) ─────────────────────
# Users sign in with their own ABS credentials. The admin token is for
# server-wide reads (libraries, items) and scans.
ABS_URL=http://host.docker.internal:13378
ABS_ADMIN_TOKEN=
# ABS_LIBRARY_IDS=                  # limit to specific library ids (comma-sep); blank = all book libs

# ── Chaptarr (approved picks are handed here to grab) ────────────────────────
CHAPTARR_URL=http://host.docker.internal:8789
CHAPTARR_API_KEY=
CHAPTARR_ROOT_FOLDER=/audiobooks/jd
CHAPTARR_QUALITY_PROFILE_ID=2
CHAPTARR_METADATA_PROFILE_ID=1

# ── Metadata (no key, no AI) ─────────────────────────────────────────────────
AUDIBLE_DOMAIN=com                  # com, co.uk, com.au, de…
# AUDNEXUS_REGION=us

# ── Suggestion engine ────────────────────────────────────────────────────────
STACKARR_SUGGEST=true
STACKARR_SUGGEST_HOURS=24
STACKARR_SUGGEST_MAX=12
STACKARR_RATING_FLOOR=4.0
STACKARR_MAX_PER_AUTHOR=2
# weights (tune without code changes)
# W_SERIES_NEXT=10
# W_SIMS_FREQ=8
# W_AUTHOR_BACKLIST=6
# W_NARRATOR=4
# W_RATING=3
# POPULARITY_DAMPEN=0.15

# ── Import lists (optional — your "Want to Read" shelves seed suggestions) ────
# GOODREADS_RSS=https://www.goodreads.com/review/list_rss/USERID?shelf=to-read
# HARDCOVER_TOKEN=

# ── Notifications (all optional) ─────────────────────────────────────────────
# Email digest (bring your own SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
# Discord webhook digest
DISCORD_WEBHOOK=
# Optional interactive Discord bot (you supply these; no AI)
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=
# Apprise targets (Telegram, ntfy, Pushover, etc. — comma-separated apprise URLs)
# APPRISE_URLS=
